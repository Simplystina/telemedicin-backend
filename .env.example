NODE_ENV=development

# ── Database ───────────────────────────────────────────────────────────────
# For LOCAL Postgres:
# DB_HOST=localhost
# DB_PORT=5432
# DB_USERNAME=postgres
# DB_PASSWORD=yourpassword
# DB_NAME=telemedicine

# For SUPABASE (get these from: Project Settings → Database → Connection Info):
# DB_HOST=db.xxxxxxxxxxxx.supabase.co
# DB_PORT=5432
# DB_USERNAME=postgres
# DB_PASSWORD=your_supabase_password
# DB_NAME=postgres

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=
DB_NAME=telemedicine

# ── Auth ───────────────────────────────────────────────────────────────────
# Use a long random string — e.g. run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_string

# ── Paystack ───────────────────────────────────────────────────────────────
# Get from: https://dashboard.paystack.com → Settings → API Keys
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── App ────────────────────────────────────────────────────────────────────
PORT=3000
CORS_ORIGIN=http://localhost:3001

# ── Agora (Video Calls) ────────────────────────────────────────────────────
# Get from: https://console.agora.io → Your Project → App ID / App Certificate
AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_app_certificate